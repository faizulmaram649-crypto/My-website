    "famous_hadiths": [
        {
            "source": "Bukhari & Muslim",
            "text": "Intentions matter. The reward depends on the intention."
        },
        
        {
            "source": "Bukhari",
            "text": "Whoever believes in Allah and His Messenger, establishes prayer and fasts in Ramadan, will enter Paradise."
        },
        
        {
            "source": "Tirmidhi",
            "text": "Religion is sincere counsel (Nasiha). Give counsel to the people."
        },
        
        {
            "source": "Muslim",
            "text": "The best among you are those who have best manners and character."
        },
        
        {
            "source": "Bukhari",
            "text": "Help your brother whether he is oppressor or being oppressed."
        },
        
        {
            "source": "Abu Dawud",
            "text": "The most beloved deeds to Allah are those done regularly."
        },
        
        {
            "source": "Bukhari",
            "text": "No one is a true believer until he loves for his brother what he loves for himself."
        },
        
        {
            "source": "Tirmidhi",
            "text": "Modesty is part of faith."
        }
